PORT=4000
FRONTEND_ORIGIN=http://localhost:5173

# ──────────────────────────────────────────────────────────────────────────────
# APIFY (powers Instagram, Twitter, LinkedIn analytics — no OAuth required)
# ──────────────────────────────────────────────────────────────────────────────
APIFY_API_TOKEN=

# Default social handles (used when no query param is passed)
INSTAGRAM_DEFAULT_USERNAME=your_instagram_username
TWITTER_DEFAULT_USERNAME=your_twitter_handle
LINKEDIN_DEFAULT_PROFILE_URL=https://www.linkedin.com/in/your-username/
TWITTER_FALLBACK_ACTOR=gentle_cloud~twitter-tweets-scraper
LINKEDIN_FALLBACK_ACTOR=

# ──────────────────────────────────────────────────────────────────────────────
# YouTube Data API v3  (still uses official API — no Apify needed)
# ──────────────────────────────────────────────────────────────────────────────
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# YouTube Analytics API (OAuth required for reach/impressions)
# Option A: Short-lived OAuth access token
YOUTUBE_OAUTH_ACCESS_TOKEN=

# Option B: Refresh-token flow (recommended for long-running backend)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# Analytics lookback window in days
YOUTUBE_ANALYTICS_LOOKBACK_DAYS=28

# ──────────────────────────────────────────────────────────────────────────────
# AI / LLM Pipeline
# ──────────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=
TAVILY_API_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# Trends — Spotify Charts
# ──────────────────────────────────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
