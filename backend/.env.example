PORT=4000
FRONTEND_ORIGIN=http://localhost:5173

# Instagram Graph API
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_IG_USER_ID=

# YouTube Data API v3
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# YouTube Analytics API (OAuth required for real reach/impressions)
# Option A: Short-lived OAuth access token
YOUTUBE_OAUTH_ACCESS_TOKEN=

# Option B: Refresh-token flow (recommended for backend)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# Analytics lookback window in days
YOUTUBE_ANALYTICS_LOOKBACK_DAYS=28

# Agent Pipeline Keys
GROQ_API_KEY=
TAVILY_API_KEY=

# Trends API Keys
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
APIFY_API_TOKEN=

# X (Twitter) API v2
TWITTER_BEARER_TOKEN=
TWITTER_DEFAULT_USERNAME=

# ─────────────────────────────────────────────────
# LinkedIn Official Developer API (OAuth 2.0)
# ─────────────────────────────────────────────────
# Step 1 → Get your Client ID & Secret from https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Step 2 → Run the OAuth flow: open http://localhost:4000/linkedin/auth in your browser
#          Required scopes: r_liteprofile r_emailaddress  (enabled by default on every dev app)
LINKEDIN_ACCESS_TOKEN=

# Step 3 → (optional) Your LinkedIn profile URL (used as a display fallback)
LINKEDIN_DEFAULT_PROFILE_URL=https://www.linkedin.com/in/your-username/
